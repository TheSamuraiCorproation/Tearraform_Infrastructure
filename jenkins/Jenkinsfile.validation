pipeline {
    agent any

    parameters {
        string(name: 'S3_BUCKET', defaultValue: '', description: 'Attack JSON bucket')
        string(name: 'S3_KEY', defaultValue: '', description: 'Attack JSON key')
        string(name: 'KALI_HOST', defaultValue: '', description: 'Kali IP')
        string(name: 'KALI_USER', defaultValue: 'kali', description: 'SSH user on Kali')
        string(name: 'KALI_WORKDIR', defaultValue: '~/security-validation/Kali_attacks', description: 'Attack directory on Kali')
    }

    stages {
        stage('Validate Inputs') {
            steps {
                script {
                    if (!params.S3_BUCKET?.trim()) error("Missing S3_BUCKET")
                    if (!params.S3_KEY?.trim()) error("Missing S3_KEY")
                    if (!params.KALI_HOST?.trim()) error("Missing KALI_HOST")
                }
            }
        }

        stage('Run Dispatcher on Kali') {
            steps {
                sh """
ssh -o StrictHostKeyChecking=no ${params.KALI_USER}@${params.KALI_HOST} '
set -e
mkdir -p ${params.KALI_WORKDIR}/incoming
aws s3 cp s3://${params.S3_BUCKET}/${params.S3_KEY} ${params.KALI_WORKDIR}/incoming/attack.json
cd ${params.KALI_WORKDIR}
chmod +x dispatcher.sh
./dispatcher.sh incoming/attack.json
'
"""
            }
        }
    }
}

<rules>

  <!-- Reverse Shell Detection -->
  <rule id="110100" level="10">
    <description>Potential reverse shell via bash -c</description>
    <match>bash -c</match>
  </rule>

  <rule id="111001" level="10">
    <description>Reverse shell pattern using /dev/tcp</description>
    <match>/dev/tcp</match>
  </rule>

  <rule id="111002" level="10">
    <description>Reverse shell using nc</description>
    <regex>nc\s+-e</regex>
  </rule>

  <rule id="111003" level="10">
    <description>Reverse shell using python</description>
    <regex>python.*socket</regex>
  </rule>

  <!-- SSH Persistence -->
  <rule id="110101" level="9">
    <description>SSH authorized_keys modified possible persistence</description>
    <match>authorized_keys</match>
  </rule>

  <!-- Execution from tmp -->
  <rule id="110102" level="8">
    <description>Execution from tmp directory</description>
    <match>/tmp/</match>
  </rule>

  <rule id="111021" level="8">
    <description>Regex match for tmp path</description>
    <regex>/tmp/.*</regex>
  </rule>

  <!-- Privilege escalation tools -->
  <rule id="110103" level="9">
    <description>find executed possible privilege escalation</description>
    <match>find</match>
  </rule>

  <rule id="110104" level="9">
    <description>nmap executed possible SUID misuse</description>
    <match>nmap</match>
  </rule>

  <rule id="110105" level="9">
    <description>bash executed from privileged context</description>
    <match>/bin/bash</match>
  </rule>

  <!-- Data exfiltration -->
  <rule id="110106" level="9">
    <description>SCP command used possible data exfiltration</description>
    <match>scp</match>
  </rule>

  <rule id="110107" level="9">
    <description>rsync command used possible data exfiltration</description>
    <match>rsync</match>
  </rule>

  <rule id="110108" level="9">
    <description>wget command used possible data download</description>
    <match>wget</match>
  </rule>

  <rule id="110109" level="9">
    <description>curl command used possible data download</description>
    <match>curl</match>
  </rule>

  <!-- Database access -->
  <rule id="110110" level="8">
    <description>MySQL client launched</description>
    <match>mysql</match>
  </rule>

  <rule id="111071" level="9">
    <description>MySQL root login attempt</description>
    <regex>mysql\s+-u\s*root</regex>
  </rule>

  <!-- Suspicious network tools -->
  <rule id="110111" level="8">
    <description>netcat usage detected</description>
    <match>nc </match>
  </rule>

  <rule id="110112" level="8">
    <description>telnet command executed</description>
    <match>telnet</match>
  </rule>

  <!-- File discovery -->
  <rule id="110113" level="7">
    <description>Searching sensitive files</description>
    <regex>find\s+.*(shadow|passwd|id_rsa)</regex>
  </rule>

  <!-- Privilege escalation -->
  <rule id="110114" level="9">
    <description>sudo usage detected</description>
    <match>sudo</match>
  </rule>

  <rule id="110115" level="10">
    <description>Attempt to spawn root shell</description>
    <regex>sudo\s+su</regex>
  </rule>

</rules>

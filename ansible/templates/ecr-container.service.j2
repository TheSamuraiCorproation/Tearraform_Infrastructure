[Unit]
Description=Container service for {{ container_name }}
After=network-online.target docker.service
Wants=network-online.target

[Service]
# stop on service stop, --rm removed to allow proper restart control is not used
ExecStartPre=-/usr/bin/docker rm -f {{ container_name }} || true
ExecStart=/usr/bin/docker run --name {{ container_name }} {{ run_args }} {{ image_full }}
ExecStop=/usr/bin/docker stop {{ container_name }} && /usr/bin/docker rm -f {{ container_name }} || true
Restart=always
RestartSec=5
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
